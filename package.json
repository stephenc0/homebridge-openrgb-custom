{
  "displayName": "Homebridge OpenRGB Advanced",
  "name": "homebridge-openrgb-advanced",
  "version": "1.0.4",
  "license": "Apache-2.0",
  "private": false,
  "description": "Control the RGB lighting of your PC components and peripherals with HomeKit. Extended fork of homebridge-openrgb.",
  "keywords": [
    "homebridge",
    "homebridge-plugin",
    "openrgb",
    "rgb",
    "homekit",
    "adaptive-lighting",
    "color-temperature"
  ],
  "maintainers": [
    "stephenc0"
  ],
  "engines": {
    "node": ">=18.0.0",
    "homebridge": ">=1.3.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/stephenc0/homebridge-openrgb-advanced"
  },
  "main": "dist/index.js",
  "scripts": {
    "lint": "eslint src/**.ts --max-warnings=0",
    "watch": "npm run build && npm link && nodemon",
    "build": "rimraf ./dist && tsc",
    "prepare": "npm run build",
    "prepublishOnly": "npm run lint && npm run build"
  },
  "dependencies": {
    "@homebridge/plugin-ui-utils": "^2.2.2",
    "color-convert": "^2.0.1",
    "openrgb-sdk": "^0.6.0"
  },
  "devDependencies": {
    "@types/color-convert": "^2.0.4",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "homebridge": "^1.8.0",
    "nodemon": "^3.1.0",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  }
}
