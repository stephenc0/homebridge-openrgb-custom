{
  "pluginAlias": "OpenRgbCustomPlatform",
  "pluginType": "platform",
  "singular": true,
  "customUi": true,
  "schema": {
    "type": "object",
    "properties": {
      "name": {
        "title": "Name",
        "type": "string",
        "required": true,
        "default": "OpenRGB",
        "description": "A name to label this plugin"
      },
      "servers": {
        "title": "Computers Running the OpenRGB SDK Server",
        "type": "array",
        "items": {
          "title": "Server",
          "type": "object",
          "properties": {
            "name": {
              "title": "Name",
              "type": "string",
              "required": true,
              "default": "My Computer",
              "description": "A name for this server"
            },
            "host": {
              "title": "Host",
              "type": "string",
              "required": true,
              "default": "localhost",
              "description": "The IP address (e.g. 10.0.0.2) or hostname (e.g. my-computer.local) that the OpenRGB SDK Server is running on"
            },
            "port": {
              "title": "Port",
              "type": "integer",
              "required": true,
              "default": 6742,
              "description": "The port number that the OpenRGB SDK Server is set to run on"
            },
            "deviceConfigs": {
              "title": "Device White Balance",
              "type": "array",
              "items": {
                "title": "Device",
                "type": "object",
                "properties": {
                  "name": {
                    "title": "Device Name",
                    "type": "string",
                    "required": true,
                    "description": "Exact device name as reported by OpenRGB"
                  },
                  "whiteBalanceR": {
                    "title": "Red",
                    "type": "integer",
                    "default": 255,
                    "minimum": 0,
                    "maximum": 255
                  },
                  "whiteBalanceG": {
                    "title": "Green",
                    "type": "integer",
                    "default": 255,
                    "minimum": 0,
                    "maximum": 255
                  },
                  "whiteBalanceB": {
                    "title": "Blue",
                    "type": "integer",
                    "default": 255,
                    "minimum": 0,
                    "maximum": 255
                  }
                }
              }
            }
          }
        }
      },
      "discoveryInterval": {
        "title": "Discovery Interval",
        "type": "integer",
        "required": true,
        "default": 60,
        "description": "How often (in seconds) to check if new devices are available"
      },
      "preserveDisconnected": {
        "title": "Preserve Disconnected Devices",
        "type": "boolean",
        "default": false,
        "description": "Keep devices in HomeKit even when disconnected from their server"
      },
      "suppressConnectionErrors": {
        "title": "Suppress Connection Errors",
        "type": "boolean",
        "default": false,
        "description": "Hide log messages about errors connecting to your PC"
      }
    }
  },
  "form": [
    "name",
    {
      "key": "servers",
      "type": "array",
      "title": "Servers",
      "buttonText": "Add Server",
      "items": [
        "servers[].name",
        "servers[].host",
        "servers[].port",
        {
          "key": "servers[].deviceConfigs",
          "type": "array",
          "title": "Device White Balance",
          "buttonText": "Add Device",
          "items": [
            "servers[].deviceConfigs[].name",
            {
              "key": "servers[].deviceConfigs[].whiteBalanceR",
              "type": "range",
              "minimum": 0,
              "maximum": 255,
              "step": 1,
              "description": "Red channel — 255 = no change"
            },
            {
              "key": "servers[].deviceConfigs[].whiteBalanceG",
              "type": "range",
              "minimum": 0,
              "maximum": 255,
              "step": 1,
              "description": "Green channel — 255 = no change"
            },
            {
              "key": "servers[].deviceConfigs[].whiteBalanceB",
              "type": "range",
              "minimum": 0,
              "maximum": 255,
              "step": 1,
              "description": "Blue channel — 255 = no change"
            }
          ]
        }
      ]
    },
    "discoveryInterval",
    "preserveDisconnected",
    "suppressConnectionErrors"
  ]
}
